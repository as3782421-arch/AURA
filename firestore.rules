rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - uid: string (required) - unique identifier
    // - email: string (required) - user email
    // - displayName: string - user name
    // - photoURL: string - profile image
    //
    // Collection: vault
    // - uid: string (required) - owner of the entry
    // - title: string (required) - title of the content
    // - type: string (required) - anime, web-series, movie, manga, game
    // - status: string (required) - watching, completed, dropped, planned
    // - rating: number - 0 to 10
    // - review: string - user thoughts
    // - watchedAt: timestamp
    //
    // Collection: brainstorming
    // - uid: string (required) - owner
    // - mediaId: string - reference to vault item or external ID
    // - content: string - AI insights/notes
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidMediaEntry(data) {
      return data.uid == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type in ['anime', 'web-series', 'movie', 'manga', 'game', 'tv-show'] &&
             data.status in ['watching', 'completed', 'dropped', 'planned'] &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 20));
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /vault/{entryId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidMediaEntry(request.resource.data);
      allow update: if isDocOwner() && isValidMediaEntry(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /brainstorming/{brainId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.uid == request.auth.uid;
      allow delete: if isDocOwner();
    }
  }
}
